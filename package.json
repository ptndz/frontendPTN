{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f .env.local next dev",
    "dev:start": "env-cmd -f .env.local next start",
    "build": "env-cmd -f .env.local next build",
    "server:build": "env-cmd -f .env.production next build",
    "server:start": "env-cmd -f .env.production next start -p 3000",
    "server:dev": "env-cmd -f .env.production next dev",
    "start": "env-cmd -f .env.production next start",
    "lint": "next lint",
    "postbuild": "cross-env next-sitemap --config next-sitemap.js",
    "codegen": "graphql-codegen --config codegen.ts --watch",
    "test:user": "ts-node ./test/userFke.ts"
  },
  "dependencies": {
    "@ptndev/json": "^1.0.5",
    "@serwist/next": "^9.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-devtools": "^5.100.5",
    "autosize": "^6.0.1",
    "axios": "^1.15.1",
    "bufferutil": "^4.0.7",
    "cookies-next": "^2.1.1",
    "cross-env": "^7.0.3",
    "env-cmd": "^10.1.0",
    "graphql": "^16.6.0",
    "graphql-request": "^5.2.0",
    "moment": "^2.29.4",
    "next": "16.2.2",
    "next-seo": "^5.15.0",
    "nprogress": "^0.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.1",
    "react-responsive-modal": "^6.4.1",
    "react-toastify": "^9.1.2",
    "react-tooltip": "^5.11.1",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "tailwind-scrollbar-hide": "^1.1.7",
    "utf-8-validate": "^6.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@graphql-codegen/cli": "^3.2.2",
    "@graphql-codegen/client-preset": "^2.1.1",
    "@graphql-codegen/introspection": "3.0.1",
    "@graphql-codegen/typescript": "^3.0.2",
    "@graphql-codegen/typescript-resolvers": "^3.1.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/autosize": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/nprogress": "^0.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-modal": "^3.16.0",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "next-sitemap": "^4.0.6",
    "postcss": "^8.4.21",
    "prettier": "3.8.3",
    "serwist": "^9.0.0",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3"
  }
}
